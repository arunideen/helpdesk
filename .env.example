# App
APP_NAME=Helpdesk System
DEBUG=true
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk

# Redis
REDIS_URL=redis://localhost:6379/0

# IMAP (incoming email)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=support@company.com
IMAP_PASSWORD=your-imap-password
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=120

# SMTP (outgoing email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=support@company.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=support@company.com
SMTP_FROM_NAME=Helpdesk Bot

# Attachments
UPLOAD_DIR=uploads
MAX_ATTACHMENT_SIZE_MB=10
MAX_TOTAL_ATTACHMENT_SIZE_MB=25
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,pdf,doc,docx,xls,xlsx,csv,txt,zip,tar.gz,log

# S3 (optional, for production)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=helpdesk-attachments
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# Auto-reply rate limit (seconds between auto-replies to the same sender)
AUTO_REPLY_COOLDOWN_SECONDS=3600
